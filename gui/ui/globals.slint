// Shared enums, globals, and theme palette.

export enum OutputFormat { jpeg, png, webp }
export enum ThumbMode { single, grid, sequence }
export enum TimestampCorner { bottom-right, bottom-left, top-right, top-left }
export enum BarSide { top, bottom }
export enum BarLayoutMode { horizontal, vertical }
export enum FontSize { auto, pixels, percent }

// All persisted user choices live here.
export global Settings {
    in-out property <string> output-dir: "";
    in-out property <OutputFormat> output-format: OutputFormat.jpeg;
    in-out property <int> quality: 85;
    in-out property <int> frame-max-width: 1920;
    in-out property <int> frame-max-height: 1080;

    in-out property <ThumbMode> mode: ThumbMode.single;
    in-out property <int> seek-percent: 10;
    in-out property <int> grid-cols: 3;
    in-out property <int> grid-rows: 3;
    in-out property <int> frame-count: 5;

    in-out property <bool> overwrite: true;
    in-out property <string> prefix: "";

    in-out property <bool> show-timestamp: false;
    in-out property <TimestampCorner> timestamp-pos: TimestampCorner.bottom-right;
    in-out property <FontSize> timestamp-size-mode: FontSize.auto;
    in-out property <int> timestamp-size: 28;
    in-out property <int> timestamp-size-percent: 5;

    in-out property <bool> show-meta-bar: false;
    in-out property <BarSide> bar-pos: BarSide.top;
    in-out property <BarLayoutMode> bar-layout: BarLayoutMode.horizontal;
    in-out property <FontSize> bar-size-mode: FontSize.auto;
    in-out property <int> bar-size: 22;
    in-out property <int> bar-size-percent: 5;
    in-out property <bool> show-branding: true;

    in-out property <bool> meta-filename: true;
    in-out property <bool> meta-duration: true;
    in-out property <bool> meta-fps: false;
    in-out property <bool> meta-resolution: false;
    in-out property <bool> meta-filesize: false;
    in-out property <bool> meta-timestamp: false;
    in-out property <bool> meta-codec: false;
    in-out property <bool> meta-bitrate: false;

    in-out property <bool> dark-theme: false;
}

// Transient UI state (not persisted).
export global GuiState {
    in-out property <float> progress: 0;
    in-out property <string> status-text: "Ready";
    in-out property <bool> is-processing: false;
    in-out property <string> log-text: "";
}

// All Rust-implemented callbacks bundled in a single global.
export global Callabler {
    callback add-files();
    callback add-folder();
    callback clear-files();
    callback remove-selected(int);
    callback select-output-dir();
    callback start();
    callback stop-processing();
    callback open-repository();
    callback toggle-theme();
}

// Bridges Slint enums to ComboBox `current-index` (which is an int).
// Keeps int discriminants in one place instead of scattered through bindings.
export global EnumIndex {
    public pure function format-to-index(f: OutputFormat) -> int {
        if f == OutputFormat.jpeg { return 0; }
        if f == OutputFormat.png { return 1; }
        return 2;
    }
    public pure function index-to-format(i: int) -> OutputFormat {
        if i == 0 { return OutputFormat.jpeg; }
        if i == 1 { return OutputFormat.png; }
        return OutputFormat.webp;
    }

    public pure function mode-to-index(m: ThumbMode) -> int {
        if m == ThumbMode.single { return 0; }
        if m == ThumbMode.grid { return 1; }
        return 2;
    }
    public pure function index-to-mode(i: int) -> ThumbMode {
        if i == 0 { return ThumbMode.single; }
        if i == 1 { return ThumbMode.grid; }
        return ThumbMode.sequence;
    }

    public pure function ts-pos-to-index(p: TimestampCorner) -> int {
        if p == TimestampCorner.bottom-right { return 0; }
        if p == TimestampCorner.bottom-left { return 1; }
        if p == TimestampCorner.top-right { return 2; }
        return 3;
    }
    public pure function index-to-ts-pos(i: int) -> TimestampCorner {
        if i == 0 { return TimestampCorner.bottom-right; }
        if i == 1 { return TimestampCorner.bottom-left; }
        if i == 2 { return TimestampCorner.top-right; }
        return TimestampCorner.top-left;
    }

    public pure function bar-pos-to-index(p: BarSide) -> int {
        if p == BarSide.top { return 0; }
        return 1;
    }
    public pure function index-to-bar-pos(i: int) -> BarSide {
        if i == 0 { return BarSide.top; }
        return BarSide.bottom;
    }

    public pure function bar-layout-to-index(l: BarLayoutMode) -> int {
        if l == BarLayoutMode.horizontal { return 0; }
        return 1;
    }
    public pure function index-to-bar-layout(i: int) -> BarLayoutMode {
        if i == 0 { return BarLayoutMode.horizontal; }
        return BarLayoutMode.vertical;
    }

    public pure function font-size-to-index(f: FontSize) -> int {
        if f == FontSize.auto { return 0; }
        if f == FontSize.pixels { return 1; }
        return 2;
    }
    public pure function index-to-font-size(i: int) -> FontSize {
        if i == 0 { return FontSize.auto; }
        if i == 1 { return FontSize.pixels; }
        return FontSize.percent;
    }
}

// Centralised colors — every value branches on Settings.dark-theme.
export global Theme {
    out property <color> window-bg:        Settings.dark-theme ? #1f1f1f : #ffffff;
    out property <color> bar-track:        Settings.dark-theme ? #3a3a3a : #e0e0e0;
    out property <color> bar-fill:         #4CAF50;
    out property <color> bar-text-on-fill: #ffffff;
    out property <color> bar-text-off-fill: Settings.dark-theme ? #e8e8e8 : #333333;
    out property <color> hint-text:        Settings.dark-theme ? #aaaaaa : #888888;
}

